#!/bin/bash

# ============================================================
#  compress-video — Interactive FFmpeg compression helper
# ============================================================

# ---------- ANSI palette ----------
BOLD='\033[1m'
DIM='\033[2m'
CYAN='\033[0;36m'
BCYAN='\033[1;36m'
GREEN='\033[1;32m'
YELLOW='\033[1;33m'
RED='\033[1;31m'
MAGENTA='\033[1;35m'
BLUE='\033[0;34m'
WHITE='\033[1;37m'
NC='\033[0m'

# ---------- Helpers ----------

print_header() {
    clear
    echo -e "${BCYAN}"
    echo '  ██╗   ██╗██╗██████╗ ███████╗ ██████╗ ██████╗ ███╗   ███╗██████╗ '
    echo '  ██║   ██║██║██╔══██╗██╔════╝██╔════╝██╔═══██╗████╗ ████║██╔══██╗'
    echo '  ██║   ██║██║██║  ██║█████╗  ██║     ██║   ██║██╔████╔██║██████╔╝'
    echo '  ╚██╗ ██╔╝██║██║  ██║██╔══╝  ██║     ██║   ██║██║╚██╔╝██║██╔═══╝ '
    echo '   ╚████╔╝ ██║██████╔╝███████╗╚██████╗╚██████╔╝██║ ╚═╝ ██║██║     '
    echo '    ╚═══╝  ╚═╝╚═════╝ ╚══════╝ ╚═════╝ ╚═════╝ ╚═╝     ╚═╝╚═╝     '
    echo -e "${NC}"
    echo -e "  ${DIM}FFmpeg-powered video compression — interactive & scriptable${NC}"
    echo -e "  ${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo
}

section() {   # section "Title"
    echo -e "\n  ${YELLOW}◆ $1${NC}"
    echo -e "  ${DIM}$(printf '─%.0s' {1..45})${NC}"
}

ok()    { echo -e "  ${GREEN}✔${NC}  $*"; }
warn()  { echo -e "  ${YELLOW}⚠${NC}  $*"; }
err()   { echo -e "  ${RED}✘${NC}  $*"; }
info()  { echo -e "  ${BLUE}ℹ${NC}  $*"; }

# Human-readable byte sizes
human_size() {
    local bytes=$1
    if   (( bytes >= 1073741824 )); then printf "%.2f GB" "$(echo "scale=2; $bytes/1073741824" | bc)"
    elif (( bytes >= 1048576 ));    then printf "%.2f MB" "$(echo "scale=2; $bytes/1048576"    | bc)"
    elif (( bytes >= 1024 ));       then printf "%.1f KB" "$(echo "scale=1; $bytes/1024"       | bc)"
    else printf "%d B" "$bytes"; fi
}

# Global — set by probe_file, used by progress bar
TOTAL_DURATION_S=""

# Inspect input file with ffprobe
probe_file() {
    local file="$1"
    section "Input File Analysis"

    if ! command -v ffprobe &>/dev/null; then
        warn "ffprobe not found — skipping file analysis."
        return
    fi

    local raw
    raw=$(ffprobe -v quiet -print_format json -show_streams -show_format "$file" 2>/dev/null)

    local duration codec_name width height bitrate size
    duration=$(echo "$raw" | grep '"duration"' | head -1 | grep -oP '[\d.]+')
    TOTAL_DURATION_S="$duration"  # export for progress bar
    codec_name=$(echo "$raw" | grep '"codec_name"' | head -1 | grep -oP '"[^"]+"' | tail -1 | tr -d '"')
    width=$(echo "$raw" | grep '"width"'  | head -1 | grep -oP '\d+')
    height=$(echo "$raw" | grep '"height"' | head -1 | grep -oP '\d+')
    bitrate=$(echo "$raw" | grep '"bit_rate"' | head -1 | grep -oP '\d+')
    size=$(stat -c%s "$file" 2>/dev/null || stat -f%z "$file" 2>/dev/null)

    # Format duration as HH:MM:SS
    local dur_fmt="unknown"
    if [[ -n "$duration" ]]; then
        local d_int=${duration%.*}
        dur_fmt=$(printf "%02d:%02d:%02d" $((d_int/3600)) $(( (d_int%3600)/60 )) $((d_int%60)))
    fi

    local br_fmt="unknown"
    if [[ -n "$bitrate" ]]; then
        br_fmt="$(( bitrate / 1000 )) kbps"
    fi

    local sz_fmt="unknown"
    [[ -n "$size" ]] && sz_fmt=$(human_size "$size")

    printf "  ${CYAN}%-14s${NC} %s\n"  "Resolution:"  "${width:-?}×${height:-?}"
    printf "  ${CYAN}%-14s${NC} %s\n"  "Codec:"       "${codec_name:-unknown}"
    printf "  ${CYAN}%-14s${NC} %s\n"  "Duration:"    "$dur_fmt"
    printf "  ${CYAN}%-14s${NC} %s\n"  "Bitrate:"     "$br_fmt"
    printf "  ${CYAN}%-14s${NC} %s\n"  "File size:"   "$sz_fmt"
}


# ---------- PROGRESS BAR ----------

run_with_progress() {
    local total_s="$1"
    shift  # remaining args are the ffmpeg command

    local BAR_WIDTH=45
    local progress_file
    progress_file=$(mktemp)

    # Run ffmpeg with machine-readable progress output
    ffmpeg "$@" -progress "$progress_file" -nostats 2>/dev/null &
    local FFMPEG_PID=$!

    local cur_s=0 speed_raw="" pct=0 eta_str="--:--"

    echo -ne "\n"

    while kill -0 "$FFMPEG_PID" 2>/dev/null; do
        if [[ -f "$progress_file" ]]; then
            local out_time_ms
            out_time_ms=$(grep '^out_time_ms=' "$progress_file" | tail -1 | cut -d= -f2)
            speed_raw=$(grep '^speed=' "$progress_file" | tail -1 | cut -d= -f2 | tr -d 'x ')

            if [[ -n "$out_time_ms" && "$out_time_ms" -gt 0 ]] 2>/dev/null; then
                cur_s=$(echo "scale=2; $out_time_ms / 1000000" | bc 2>/dev/null || echo 0)

                if [[ -n "$total_s" && $(echo "$total_s > 0" | bc 2>/dev/null) -eq 1 ]]; then
                    pct=$(echo "scale=2; $cur_s * 100 / $total_s" | bc 2>/dev/null || echo 0)
                    pct=${pct%.*}
                    (( pct > 100 )) && pct=100

                    if [[ -n "$speed_raw" && $(echo "$speed_raw > 0" | bc 2>/dev/null) -eq 1 ]]; then
                        local remaining eta_s
                        remaining=$(echo "scale=2; $total_s - $cur_s" | bc 2>/dev/null || echo 0)
                        eta_s=$(echo "scale=0; $remaining / $speed_raw" | bc 2>/dev/null || echo 0)
                        local em es
                        em=$(( eta_s / 60 ))
                        es=$(( eta_s % 60 ))
                        eta_str=$(printf "%02d:%02d" "$em" "$es")
                    fi
                fi
            fi
        fi

        # Draw bar
        pct=${pct:-0}
        local filled=$(( pct * BAR_WIDTH / 100 ))
        local empty=$(( BAR_WIDTH - filled ))
        local bar="${CYAN}"
        for (( i=0; i<filled; i++ )); do bar+="█"; done
        bar+="${DIM}"
        for (( i=0; i<empty; i++ )); do bar+="░"; done
        bar+="${NC}"

        local spd_disp="${speed_raw:-?}x"
        printf "\r  [%b] ${WHITE}%3d%%${NC}  ETA ${YELLOW}%s${NC}  ${DIM}@ %s${NC}   " \
            "$bar" "$pct" "$eta_str" "$spd_disp"

        sleep 0.5
    done

    wait "$FFMPEG_PID"
    local EXIT_CODE=$?
    rm -f "$progress_file"

    if [[ $EXIT_CODE -eq 0 ]]; then
        local full_bar="${GREEN}"
        for (( i=0; i<BAR_WIDTH; i++ )); do full_bar+="█"; done
        full_bar+="${NC}"
        printf "\r  [%b] ${WHITE}100%%${NC}  ${GREEN}✔ Done!${NC}%*s\n" \
            "$full_bar" 20 ""
    fi

    return $EXIT_CODE
}

# ---------- HELP ----------

print_help() {
    print_header
    echo -e "  ${WHITE}USAGE${NC}"
    echo -e "    ${GREEN}compress-video${NC}                    # launch interactive TUI"
    echo -e "    ${GREEN}compress-video${NC} ${CYAN}-h${NC}|${CYAN}--help${NC}           # show this help"
    echo
    echo -e "  ${WHITE}DESCRIPTION${NC}"
    echo -e "    An interactive wrapper around FFmpeg that walks you through"
    echo -e "    codec selection, quality tuning, and optional trimming — then"
    echo -e "    shows a before/after size report when done."
    echo
    echo -e "  ${WHITE}CODECS AVAILABLE${NC}"
    printf "    ${CYAN}%-22s${NC} %s\n" "H.265 / HEVC  (CPU)"  "Best balance of size & compatibility. Widely supported."
    printf "    ${CYAN}%-22s${NC} %s\n" "AV1           (CPU)"  "Smallest files. Cutting-edge; slower encode. Output: .mkv"
    printf "    ${CYAN}%-22s${NC} %s\n" "HEVC NVENC (NVIDIA)"  "GPU-accelerated. Very fast; requires NVIDIA card + drivers."
    echo
    echo -e "  ${WHITE}QUALITY PRESETS (CRF-based)${NC}"
    printf "    ${CYAN}%-8s${NC}  H.265 → crf 23  │  AV1 → crf 26  │  NVENC → cq 24\n" "High:"
    printf "    ${CYAN}%-8s${NC}  H.265 → crf 28  │  AV1 → crf 35  │  NVENC → cq 28\n" "Med:"
    printf "    ${CYAN}%-8s${NC}  H.265 → crf 34  │  AV1 → crf 42  │  NVENC → cq 34\n" "Low:"
    echo
    echo -e "  ${WHITE}TRIMMING${NC}"
    echo -e "    Accepts ${CYAN}HH:MM:SS${NC} or plain seconds (e.g. ${CYAN}90${NC} = 1 min 30 sec)."
    echo -e "    Start-only, end-only, or both are all valid combinations."
    echo
    echo -e "  ${WHITE}EXAMPLES${NC}"
    echo -e "    Run the interactive TUI:"
    echo -e "      ${GREEN}compress-video${NC}"
    echo
    echo -e "    Show this help:"
    echo -e "      ${GREEN}compress-video --help${NC}"
    echo
    echo -e "  ${WHITE}DEPENDENCIES${NC}"
    echo -e "    ${CYAN}ffmpeg${NC}   Required for encoding"
    echo -e "    ${CYAN}ffprobe${NC}  Optional — enables file analysis before encoding"
    echo -e "    ${CYAN}bc${NC}       Optional — needed for human-readable size formatting"
    echo
    echo -e "  ${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo
}

# ---------- HELP FLAG ----------

if [[ "$1" == "-h" || "$1" == "--help" ]]; then
    print_help
    exit 0
fi

# ---------- INTERACTIVE MODE ----------

if [ $# -eq 0 ]; then
    print_header

    # ── 1. Input File ──────────────────────────────────────────────
    section "Input File"
    read -e -p "  Drag & drop or type input file path: " INPUT
    INPUT="${INPUT%\"}"
    INPUT="${INPUT#\"}"
    INPUT="${INPUT% }"   # strip trailing space from drag-and-drop

    if [ ! -f "$INPUT" ]; then
        err "File not found: $INPUT"
        exit 1
    fi
    ok "File found: $(basename "$INPUT")"

    probe_file "$INPUT"

    # ── 2. Output File ─────────────────────────────────────────────
    section "Output File"
    FILENAME=$(basename -- "$INPUT")
    BASENAME="${FILENAME%.*}"
    DIRNAME=$(dirname -- "$INPUT")
    DEFAULT_OUT="${DIRNAME}/${BASENAME}_compressed.mp4"

    echo -ne "  Output path [Enter = ${DIM}$DEFAULT_OUT${NC}]: "
    read -e OUTPUT
    OUTPUT=${OUTPUT:-$DEFAULT_OUT}

    # ── 3. Codec ───────────────────────────────────────────────────
    section "Codec / Hardware Acceleration"
    echo -e "  ${WHITE}1)${NC} H.265 / HEVC ${DIM}(CPU)${NC}         Best balance of size and compatibility"
    echo -e "  ${WHITE}2)${NC} AV1          ${DIM}(CPU)${NC}         Smallest file size — cutting-edge, slower"
    echo -e "  ${WHITE}3)${NC} HEVC NVENC   ${DIM}(NVIDIA GPU)${NC}  Blazing fast — requires NVIDIA card"
    echo
    read -p "  Choose [1-3] (default: 1): " CODEC_CHOICE
    CODEC_CHOICE=${CODEC_CHOICE:-1}

    # NVENC sanity check
    if [[ "$CODEC_CHOICE" == "3" ]]; then
        if ! nvidia-smi &>/dev/null; then
            warn "nvidia-smi not detected. NVENC may fail if no NVIDIA GPU is present."
            read -p "  Continue anyway? [y/N]: " NVENC_CONT
            if [[ ! "$NVENC_CONT" =~ ^[Yy]$ ]]; then
                info "Falling back to H.265 (CPU)."
                CODEC_CHOICE=1
            fi
        else
            ok "NVIDIA GPU detected."
        fi
    fi

    # ── 4. Quality ─────────────────────────────────────────────────
    section "Quality Preset"
    echo -e "  ${WHITE}1)${NC} High  ${DIM}Visually lossless — larger file${NC}"
    echo -e "  ${WHITE}2)${NC} Med   ${DIM}Great for sharing / Discord${NC}   ${YELLOW}(recommended)${NC}"
    echo -e "  ${WHITE}3)${NC} Low   ${DIM}Aggressive compression — small file${NC}"
    echo
    read -p "  Choose [1-3] (default: 2): " QUAL_CHOICE
    QUAL_CHOICE=${QUAL_CHOICE:-2}

    # ── 5. Trimming ────────────────────────────────────────────────
    section "Trim (optional)"
    read -p "  Trim the video? [y/N]: " TRIM_CHOICE
    TRIM_START=""
    TRIM_END=""
    if [[ "$TRIM_CHOICE" =~ ^[Yy]$ ]]; then
        read -p "  Start time [HH:MM:SS or seconds, blank to skip]: " TRIM_START
        read -p "  End time   [HH:MM:SS or seconds, blank to skip]: " TRIM_END
    fi

    # ── Map choices to FFmpeg flags ────────────────────────────────
    FF_CODEC=""
    FF_QUALITY=""
    CODEC_LABEL=""

    case $CODEC_CHOICE in
        2)
            FF_CODEC="-c:v libsvtav1 -preset 8"
            CODEC_LABEL="AV1 (libsvtav1)"
            case $QUAL_CHOICE in
                1) FF_QUALITY="-crf 26" ;;
                2) FF_QUALITY="-crf 35" ;;
                3) FF_QUALITY="-crf 42" ;;
            esac
            OUTPUT="${OUTPUT%.*}.mkv"
            ;;
        3)
            FF_CODEC="-c:v hevc_nvenc -preset p4"
            CODEC_LABEL="HEVC NVENC (GPU)"
            case $QUAL_CHOICE in
                1) FF_QUALITY="-rc vbr -cq 24" ;;
                2) FF_QUALITY="-rc vbr -cq 28" ;;
                3) FF_QUALITY="-rc vbr -cq 34" ;;
            esac
            ;;
        *)
            FF_CODEC="-c:v libx265 -preset fast"
            CODEC_LABEL="H.265 / HEVC (CPU)"
            case $QUAL_CHOICE in
                1) FF_QUALITY="-crf 23" ;;
                2) FF_QUALITY="-crf 28" ;;
                3) FF_QUALITY="-crf 34" ;;
            esac
            ;;
    esac

    case $QUAL_CHOICE in
        1) QUAL_LABEL="High" ;;
        3) QUAL_LABEL="Low"  ;;
        *) QUAL_LABEL="Med"  ;;
    esac

    FF_TRIM=""
    TRIM_STR="${DIM}None${NC}"
    if [ -n "$TRIM_START" ]; then
        FF_TRIM="-ss $TRIM_START"
        TRIM_STR="${CYAN}Start:${NC} $TRIM_START"
    fi
    if [ -n "$TRIM_END" ]; then
        FF_TRIM="$FF_TRIM -to $TRIM_END"
        if [ -z "$TRIM_START" ]; then
            TRIM_STR="${CYAN}End:${NC} $TRIM_END"
        else
            TRIM_STR="${CYAN}Start:${NC} $TRIM_START  ${CYAN}End:${NC} $TRIM_END"
        fi
    fi

    # ── 6. Summary & Confirm ───────────────────────────────────────
    print_header
    section "Summary"
    printf "  ${CYAN}%-14s${NC} %s\n"   "Input:"    "$(basename "$INPUT")"
    printf "  ${CYAN}%-14s${NC} %s\n"   "Output:"   "$OUTPUT"
    echo -e "  ${CYAN}Trim:${NC}          $TRIM_STR"
    printf "  ${CYAN}%-14s${NC} %s\n"   "Codec:"    "$CODEC_LABEL"
    printf "  ${CYAN}%-14s${NC} %s  ${DIM}(%s)${NC}\n" "Quality:" "$QUAL_LABEL" "$FF_QUALITY"
    echo
    echo -e "  ${DIM}Note: CRF output size varies with scene complexity.${NC}"
    echo -e "  ${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo

    read -p "  Proceed with compression? [y/N]: " CONFIRM
    if [[ ! "$CONFIRM" =~ ^[Yy]$ ]]; then
        err "Operation aborted."
        exit 0
    fi

    # ── 7. Encode ──────────────────────────────────────────────────
    echo
    echo -e "  ${GREEN}Starting FFmpeg...${NC}"
    echo -e "  ${DIM}codec: $CODEC_LABEL  |  quality: $QUAL_LABEL  |  source: $(basename "$INPUT")${NC}\n"

    # Capture size before
    SIZE_BEFORE=$(stat -c%s "$INPUT" 2>/dev/null || stat -f%z "$INPUT" 2>/dev/null)

    run_with_progress "$TOTAL_DURATION_S" $FF_TRIM -i "$INPUT" $FF_CODEC $FF_QUALITY -c:a copy "$OUTPUT"
    FFMPEG_EXIT=$?
    echo

    # ── 8. Result report ───────────────────────────────────────────
    if [ $FFMPEG_EXIT -ne 0 ]; then
        err "FFmpeg exited with error code $FFMPEG_EXIT."
        exit $FFMPEG_EXIT
    fi

    section "Compression Report"

    SIZE_AFTER=$(stat -c%s "$OUTPUT" 2>/dev/null || stat -f%z "$OUTPUT" 2>/dev/null)

    if [[ -n "$SIZE_BEFORE" && -n "$SIZE_AFTER" && "$SIZE_BEFORE" -gt 0 ]]; then
        SAVED=$(( SIZE_BEFORE - SIZE_AFTER ))
        PCT=$(echo "scale=1; ($SAVED * 100) / $SIZE_BEFORE" | bc 2>/dev/null || echo "?")

        printf "  ${CYAN}%-16s${NC} %s\n"  "Input size:"   "$(human_size "$SIZE_BEFORE")"
        printf "  ${CYAN}%-16s${NC} %s\n"  "Output size:"  "$(human_size "$SIZE_AFTER")"

        if (( SAVED > 0 )); then
            printf "  ${GREEN}%-16s${NC} %s saved ${GREEN}(%.0f%% smaller)${NC}\n" \
                "Space saved:" "$(human_size "$SAVED")" "$PCT"
        else
            printf "  ${YELLOW}%-16s${NC} Output is %s larger than input\n" \
                "Note:" "$(human_size $(( -SAVED )))"
        fi
    fi

    echo
    ok "Done! Saved to: ${WHITE}$OUTPUT${NC}"
    echo
    exit 0
fi

# ---------- CLI FALLBACK ----------
echo -e "${YELLOW}Run without arguments to launch the interactive TUI.${NC}"
echo -e "Use ${CYAN}compress-video --help${NC} for documentation."
exit 0