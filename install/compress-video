#!/bin/bash

CYAN='\033[0;36m'
GREEN='\033[1;32m'
YELLOW='\033[1;33m'
RED='\033[1;31m'
DIM='\033[2m'
NC='\033[0m'

TOOL_NAME="compress-video"
INSTALL_DIR="/usr/local/bin"
SCRIPT_URL="https://get.notvc.to/compress-video"
INSTALL_PATH="$INSTALL_DIR/$TOOL_NAME"

echo
echo -e "  ${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "  ${GREEN}  Installing $TOOL_NAME${NC}"
echo -e "  ${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo

# ── Dependency check ────────────────────────────────────────
if ! command -v ffmpeg &>/dev/null; then
    echo -e "  ${YELLOW}⚠${NC}  ffmpeg not found — $TOOL_NAME requires it to function."
    echo -e "     Install it first:"
    echo -e "     ${DIM}Debian/Ubuntu:${NC}  sudo apt install ffmpeg"
    echo -e "     ${DIM}Arch:${NC}           sudo pacman -S ffmpeg"
    echo -e "     ${DIM}Fedora:${NC}         sudo dnf install ffmpeg"
    echo
    read -p "  Continue installing anyway? [y/N]: " CONT
    [[ ! "$CONT" =~ ^[Yy]$ ]] && echo -e "\n  ${RED}Aborted.${NC}\n" && exit 0
    echo
fi

# ── Explain what's about to happen ──────────────────────────
echo -e "  ${CYAN}This installer will:${NC}"
echo -e "  ${DIM}1.${NC} Download ${CYAN}$SCRIPT_URL${NC}"
echo -e "  ${DIM}2.${NC} Write it to ${CYAN}$INSTALL_PATH${NC}  ${DIM}(requires sudo)${NC}"
echo -e "  ${DIM}3.${NC} Run ${CYAN}chmod +x $INSTALL_PATH${NC}  ${DIM}(requires sudo)${NC}"
echo
read -p "  Proceed? [y/N]: " CONFIRM
[[ ! "$CONFIRM" =~ ^[Yy]$ ]] && echo -e "\n  ${RED}Aborted.${NC}\n" && exit 0
echo

# ── Download ─────────────────────────────────────────────────
echo -e "  ${DIM}Downloading...${NC}"
TMP=$(mktemp)
if ! curl -fsSL "$SCRIPT_URL" -o "$TMP"; then
    echo -e "  ${RED}✘  Download failed. Check your connection and try again.${NC}\n"
    rm -f "$TMP"
    exit 1
fi
echo -e "  ${GREEN}✔${NC}  Downloaded successfully"

# ── Install (explicit sudo calls) ───────────────────────────
echo
echo -e "  ${YELLOW}Sudo is required to write to $INSTALL_DIR — you may be prompted for your password.${NC}"
echo

echo -e "  ${DIM}Running: sudo tee $INSTALL_PATH${NC}"
if ! sudo tee "$INSTALL_PATH" < "$TMP" > /dev/null; then
    echo -e "  ${RED}✘  Failed to write to $INSTALL_PATH.${NC}\n"
    rm -f "$TMP"
    exit 1
fi
echo -e "  ${GREEN}✔${NC}  Wrote to $INSTALL_PATH"

echo -e "  ${DIM}Running: sudo chmod +x $INSTALL_PATH${NC}"
if ! sudo chmod +x "$INSTALL_PATH"; then
    echo -e "  ${RED}✘  Failed to set executable permissions.${NC}\n"
    rm -f "$TMP"
    exit 1
fi
echo -e "  ${GREEN}✔${NC}  Set executable permissions"

rm -f "$TMP"

# ── Done ─────────────────────────────────────────────────────
echo
echo -e "  ${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "  ${GREEN}  Done! Run it with:  compress-video${NC}"
echo -e "  ${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo
